<?xml version="1.0" encoding="UTF-8"?>
<manifest:manifest xmlns:manifest="http://openoffice.org">
    
    <!-- Интеграция кнопки управления темой в главное и контекстные меню -->
    <manifest:file-entry manifest:full-path="registry/data/org/openoffice/Office/Addons.xcu" manifest:media-type="text/xml"/>
    
    <!-- Переключение классических панелей на современную ленту Ribbon -->
    <manifest:file-entry manifest:full-path="registry/data/org/openoffice/Office/UI.xcu" manifest:media-type="text/xml"/>
    
    <!-- Регистрация горячих клавиш в стиле MS Office (Поиск, замена, гиперссылки) -->
    <manifest:file-entry manifest:full-path="registry/data/org/openoffice/Office/Accelerators.xcu" manifest:media-type="text/xml"/>
    
    <!-- Принудительная подмена системных шрифтов интерфейса на Microsoft Aptos Display -->
    <manifest:file-entry manifest:full-path="registry/data/org/openoffice/Office/Common.xcu" manifest:media-type="text/xml"/>
    
    <!-- Триггер автоматического запуска макроса адаптации темы при старте пакета -->
    <manifest:file-entry manifest:full-path="registry/data/org/openoffice/Office/Jobs.xcu" manifest:media-type="text/xml"/>
    
    <!-- Базовые параметры статической цветовой палитры для Writer, Calc, Impress и др. -->
    <manifest:file-entry manifest:full-path="registry/data/org/openoffice/View.xcu" manifest:media-type="text/xml"/>
    
    <!-- Описание метаданных и структуры библиотеки встроенных макросов -->
    <manifest:file-entry manifest:full-path="Macros/script.xlb" manifest:media-type="text/xml"/>
    
    <!-- Графическая разметка диалогового окна ручного переключения тем -->
    <manifest:file-entry manifest:full-path="Macros/ThemeDialog.xdl" manifest:media-type="text/xml"/>
    
    <!-- Исходный код StarBasic макроса динамической смены тем и иконок -->
    <manifest:file-entry manifest:full-path="Macros/ThemeSwitcher.xba" manifest:media-type="text/xml"/>
    
    <!-- Оптимизированный пакет светлых иконок Colibre (MS Office Style) из LibreOffice -->
    <manifest:file-entry manifest:full-path="icons/images_ms2022.zip" manifest:media-type="application/zip"/>

    <!-- Оптимизированный пакет темных иконок Colibre Dark для ночного режима работы -->
    <manifest:file-entry manifest:full-path="icons/images_ms2022_dark.zip" manifest:media-type="application/zip"/>
    
</manifest:manifest>
