<?xml version="1.0" encoding="UTF-8"?>
<description xmlns="http://openoffice.org"
             xmlns:xlink="http://w3.org"
             xmlns:ooo="http://openoffice.org">

    <!-- Уникальный идентификатор расширения в системе UNO -->
    <identifier value="org.openoffice.msoffice.theme.2022"/>

    <!-- Версия нашего расширения -->
    <version value="1.0.0"/>

    <!-- Отображаемое имя расширения в Менеджере расширений -->
    <display-name>
        <value xml:lang="ru">Глубокая оптимизация интерфейса в стиль MS Office 2022</value>
        <value xml:lang="en">MS Office 2022 Deep Interface Optimization Theme</value>
    </display-name>

    <!-- Информация об авторе/издателе -->
    <publisher>
        <value xml:lang="ru">OpenOffice Customization Team</value>
        <value xml:lang="en">OpenOffice Customization Team</value>
    </publisher>

    <!-- Иконка расширения в списке менеджера (опционально) -->
    <icon>
        <default xlink:href="icons/res/cmd/sc_open.png"/>
    </icon>

    <!-- Требования к минимальной версии офисного пакета -->
    <dependencies>
        <ooo:OpenOffice.org-minimal-version value="26.2" ooo:name="OpenOffice.org 26.2"/>
    </dependencies>

</description>
